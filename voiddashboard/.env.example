# Public frontend envs (safe for browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Serverless API envs (Vercel only; never expose in browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DASHBOARD_BOT_API_KEY=generate-a-long-random-secret
DASHBOARD_ADMIN_DISCORD_IDS=123456789012345678,234567890123456789

# Production Discord authorization (server-side only)
DISCORD_BOT_TOKEN=your-production-discord-bot-token
DASHBOARD_AUTH_GUILD_ID=your-production-server-id
DASHBOARD_AUTH_ROLE_IDS=staff-role-id,optional-second-staff-role-id
